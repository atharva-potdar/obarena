# Environment-specific variables
environment  = "prod"
region       = "us-east-1"
cluster_name = "obarena-platform"

# SSH access — required
ssh_public_key = "ssh-rsa AAAA... user@host"
admin_cidr     = "203.0.113.0/32"  # Lock down to your IP

# Ubuntu 24.04 LTS AMI — update per region
# ubuntu_ami = "ami-0a0e5d9c7acc336f1"

# To override default instance types or sizing, uncomment and edit:
# controller_instance_type = "t3.medium"
# platform_instance_type   = "m5.xlarge"
# platform_count           = 2
# sandbox_instance_type    = "c5.4xlarge"
# sandbox_count            = 2
